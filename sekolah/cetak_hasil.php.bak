  .pred-A, .pred-B { background: #dcfce7; color: #15803d; border: 1px solid #86efac; }
  .pred-C { background: #e0f2fe; color: #075985; border: 1px solid #7dd3fc; }
  .pred-D { background: #fef9c3; color: #854d0e; border: 1px solid #fde68a; }
  .pred-E { background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; }

  .kkm-line td { background: #fef3c7 !important; border-top: 2px dashed #f59e0b !important; }
  .kkm-line td span { font-size: 8pt; color: #92400e; font-weight: 700; }

  /* ── Footer tabel ── */
