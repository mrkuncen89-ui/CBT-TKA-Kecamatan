  }
  .ttd-box { text-align: center; width: 180px; }
  .ttd-box .ttd-space { height: 50px; border-bottom: 1px solid #333; margin: 0 20px 4px; }
  .ttd-box p { font-size: 9pt; color: #333; }

  /* ── Tombol (tidak dicetak) ── */
  .no-print {
    text-align: center;
