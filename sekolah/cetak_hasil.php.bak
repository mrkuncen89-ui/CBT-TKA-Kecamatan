  .nilai-cell { font-weight: 900; font-size: 11pt; color: #1e3a8a; text-align: center; }
  .benar  { color: #15803d; font-weight: 700; text-align: center; }
  .salah  { color: #b91c1c; font-weight: 700; text-align: center; }

  .predikat {
    display: inline-block;
