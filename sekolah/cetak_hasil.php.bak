    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .doc-header .judul { flex: 1; }
  .doc-header h1 { font-size: 14pt; font-weight: 900; color: #1e3a8a; text-transform: uppercase; margin-bottom: 2px; }
  .doc-header h2 { font-size: 11pt; font-weight: 700; color: #1e3a8a; margin-bottom: 2px; }
  .doc-header p  { font-size: 9pt; color: #555; }
