    <p><?= e($namaKec) ?> &nbsp;·&nbsp; Tahun Pelajaran <?= e($tahunPel) ?> &nbsp;·&nbsp; Kategori: <?= e($namaKat) ?></p>
  </div>
  <div class="meta">
    <div>Dicetak: <?= $tanggalCetak ?></div>
    <div>KKM: <?= $kkm ?></div>
    <div>Total Peserta: <?= $total ?></div>
  </div>
</div>

<!-- Info statistik -->
<div class="info-bar">
  <div><span class="lbl">Total Peserta</span><span class="val"><?= $total ?></span></div>
  <div><span class="lbl">Nilai Tertinggi</span><span class="val"><?= $maks ?></span></div>
  <div><span class="lbl">Nilai Terendah</span><span class="val"><?= $min ?></span></div>
  <div><span class="lbl">Rata-rata</span><span class="val"><?= $rata ?></span></div>
  <div><span class="lbl">Lulus (≥<?= $kkm ?>)</span><span class="val"><?= $lulus ?> / <?= $total ?></span></div>
  <div><span class="lbl">Persentase Lulus</span><span class="val"><?= $total > 0 ? round($lulus / $total * 100) : 0 ?>%</span></div>
</div>

<!-- Tabel Peringkat -->
<table>
  <thead>
    <tr>
      <th style="width:40px" class="center">No</th>
      <th style="width:28px" class="center">Rank</th>
      <th>Nama Peserta</th>
      <th style="width:90px">Kode</th>
      <th style="width:50px" class="center">Kelas</th>
      <th>Kategori/Mapel</th>
      <th style="width:45px" class="center">Benar</th>
      <th style="width:45px" class="center">Salah</th>
      <th style="width:45px" class="center">Kosong</th>
      <th style="width:55px" class="center">Nilai</th>
      <th style="width:70px" class="center">Predikat</th>
      <th style="width:55px" class="center">Durasi</th>
      <th style="width:110px">Tgl Selesai</th>
    </tr>
  </thead>
  <tbody>
<?php
if (empty($rows)):
?>
    <tr><td colspan="13" style="text-align:center;padding:20px;color:#888">Belum ada data hasil ujian.</td></tr>
<?php
else:
    $kkmLinePrinted = false;
    foreach ($rows as $i => $h):
        $rank      = $i + 1;
        $nilaiInt  = (int)$h['nilai'];
        $benar     = (int)($h['jml_benar']  ?? 0);
        $salah     = (int)($h['jml_salah']  ?? 0);
        $kosong    = (int)($h['jml_kosong'] ?? 0);
        $durasi    = $h['durasi_menit'] !== null ? $h['durasi_menit'] . ' mnt' : '-';
        [$pred]    = getPredikat($nilaiInt);
        $isLulus   = $nilaiInt >= $kkm;
        $rowClass  = $isLulus ? 'lulus-row' : 'gagal-row';

        // Garis pemisah KKM
        if (!$kkmLinePrinted && !$isLulus):
            $kkmLinePrinted = true;
?>
    <tr class="kkm-line">
      <td colspan="13"><span>▼ Di bawah KKM (<?= $kkm ?>)</span></td>
    </tr>
<?php
        endif;
?>
    <tr class="<?= $rowClass ?>">
      <td class="center"><?= $rank ?></td>
      <td class="center rank-<?= $rank <= 3 ? 'medal' : 'num' ?>">
        <?php if ($rank === 1): ?>🥇
        <?php elseif ($rank === 2): ?>🥈
        <?php elseif ($rank === 3): ?>🥉
        <?php else: ?><span class="rank-num"><?= $rank ?></span>
        <?php endif; ?>
      </td>
      <td class="nama-peserta"><?= e($h['nama']) ?></td>
      <td class="kode"><?= e($h['kode_peserta']) ?></td>
      <td class="center"><?= e($h['kelas'] ?? '-') ?></td>
      <td><?= e($h['nama_kategori'] ?? '-') ?></td>
      <td class="benar"><?= $benar ?></td>
      <td class="salah"><?= $salah ?></td>
      <td class="center" style="color:#64748b"><?= $kosong ?></td>
      <td class="nilai-cell"><?= $h['nilai'] ?></td>
      <td class="center"><span class="predikat pred-<?= $pred ?>"><?= $pred ?></span></td>
      <td class="center"><?= $durasi ?></td>
      <td><?= $h['waktu_selesai'] ? date('d/m/Y H:i', strtotime($h['waktu_selesai'])) : '-' ?></td>
    </tr>
<?php
    endforeach;
endif;
?>
  </tbody>
  <tfoot>
    <tr class="tfoot-stat">
      <td colspan="6" style="text-align:left">Jumlah Peserta: <?= $total ?> &nbsp;|&nbsp; Lulus: <?= $lulus ?> &nbsp;|&nbsp; Tidak Lulus: <?= $total - $lulus ?></td>
      <td class="center"><?= $total > 0 ? round(array_sum(array_column($rows, 'jml_benar')) / $total, 1) : 0 ?></td>
      <td class="center"><?= $total > 0 ? round(array_sum(array_column($rows, 'jml_salah')) / $total, 1) : 0 ?></td>
      <td class="center">-</td>
      <td class="center"><?= $rata ?></td>
      <td colspan="3" style="text-align:left">Rata-rata nilai: <?= $rata ?></td>
    </tr>
  </tfoot>
</table>

